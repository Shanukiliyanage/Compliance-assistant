# Backend config
PORT=5000
DEBUG_BACKEND=1

# Firestore (optional)
# Enable Firestore persistence. If disabled, backend uses JSON files in backend/data
FIRESTORE_ENABLED=0

# Option A (recommended locally): point to a Firebase service account key file
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\serviceAccountKey.json

# Option B: paste the entire service account JSON as a single line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
